# Copy to .env and adjust as needed. docker-compose reads these.

# --- Postgres ---
POSTGRES_USER=streamflix
POSTGRES_PASSWORD=streamflix
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
OLTP_DB=streaming_oltp
OLAP_DB=streaming_olap

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# --- JWT (shared secret across services; must be >= 32 bytes for HS256) ---
JWT_SECRET=change-me-streamflix-super-secret-key-please-rotate-0123456789
JWT_EXPIRATION_MS=86400000

# --- Caching toggle (used by benchmark to compare cold vs cached) ---
CACHE_ENABLED=true

# --- Continuous synthetic traffic generator (simulated live users) ---
APP_TRAFFIC_ENABLED=true

# --- YouTube Data API key. Enriches the seeded catalog AND is required by
#     scripts/youtube-catalog-pull.mjs to build the large cached catalog. Blank = curated JSON seed. ---
YOUTUBE_API_KEY=

# --- OLTP streaming load simulator -----------------------------------------
# Synthetic users seeded by BulkUserSeeder (0 = off; set e.g. 50000 before a load test).
APP_SEED_USERS=0
# k6 load profile (profile: loadtest). BASE_URL defaults to the in-network gateway.
TARGET_EPS=500
READ_VUS=50
DURATION=5m
USER_POOL=200
USE_SEEDED_USERS=true
# k6 remote-write target (Prometheus). Leave default when using the monitoring profile.
K6_PROMETHEUS_RW_SERVER_URL=http://prometheus:9090/api/v1/write

# --- Grafana admin password (profile: monitoring) ---
GRAFANA_PASSWORD=admin
